   "source": [
    "from matplotlib import pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "sample = np.array([0, 1, 0.5, 1, 0, 1])\n",
    "\n",
    "print(sample)\n",
    "\n",
    "bitmap = sample.reshape((2,3))\n",
    "\n",
    "plt.imshow(bitmap, cmap='gray', interpolation = 'nearest')\n",
    "\n",
    "plt.show\n",
    "\n"
   ]
