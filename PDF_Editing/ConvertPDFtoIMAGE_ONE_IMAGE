from pdf2image import convert_from_path
from PIL import Image

path_to_pdf = "C:/Users/tombe/Google Drive/20241126-Liver_Function_Test_Result_November_2024.pdf"
poppler_path = r"C:\Users\tombe\Documents\PythonProjects\Release-25.07.0-0\poppler-25.07.0\Library\bin"

pages = convert_from_path(path_to_pdf, 150, poppler_path=poppler_path)


# Convert all pages to RGB (JPG doesn't support RGBA)
rgb_pages = [page.convert("RGB") for page in pages]

# Calculate total height and max width
widths, heights = zip(*(i.size for i in rgb_pages))
total_height = sum(heights)
max_width = max(widths)

# Create a single blank image and paste pages into it
combined = Image.new("RGB", (max_width, total_height), "white")

y_offset = 0
for page in rgb_pages:
    combined.paste(page, (0, y_offset))
    y_offset += page.size[1]

# Save as one file (choose PNG or JPG)
combined.save("combined_output.jpg",quality=85)  # or "combined_output.jpg"

