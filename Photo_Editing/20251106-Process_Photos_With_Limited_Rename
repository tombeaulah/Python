
from pathlib import Path
import subprocess, shlex, os
import shutil
import re

#Code created 6th November 2025
#The code will move files from one source folder to the target folder
#The code then re-dates the photos using the "Date" Parameter so that they show in the correct order within Google Photos


exiftool = r"C:\Program Files\Exiftools\exiftool.exe"
source = Path(r"C:\Users\tombe\Pictures\Miscellaneous\Scanned Photos\2025-Processing")
target = Path(r"C:\Users\tombe\Pictures\Miscellaneous\Scanned Photos\2007-Wedding_Table_Photos")
ext = ".jpg"  
#This code is for moving with renaming

base_name = "PhotoScan"   # prefix before number
next_num = 31
ext = ".jpg"              # extension (case-insensitive)

print(f"Next number will start at: {next_num}")

# --- move & rename files sequentially ---

# Regex to extract the number from filenames like PhotoScan (23).jpg
num_pattern = re.compile(r"\((\d+)\)")

def numeric_key(path: Path):
    """Extract number inside parentheses for sorting, e.g. (23) → 23."""
    m = num_pattern.search(path.stem)
    return int(m.group(1)) if m else 0  # fallback to 0 if no match

# Sort files by numeric part
files = sorted(source.glob(f"*{ext}"), key=numeric_key)

print(f"Next number will start at: {next_num}")

# --- move & rename files sequentially ---
for file_path in files:
    new_name = f"{base_name} ({next_num}){ext}"
    dest_path = target / new_name
    shutil.move(str(file_path), str(dest_path))
    print(f"Moved {file_path.name} → {new_name}")
    next_num += 1


