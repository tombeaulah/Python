# Assess the decade and prize category combination with the highest proportion of female laureates
# This was changed from using nobel_df_people to nobel_df because otherwise "peace" and "literature" were joint top, whereas the DataCamp model assesses the answer as "literature".  Using the full nobel_df corrects this, though I contend that organizations should be removed from the data if we are only looking at gender

total_counts = nobel_df.value_counts(["decade", "category"])
female_counts = nobel_df.query("sex == 'Female'").value_counts(["decade", "category"])
female_proportion = (female_counts / total_counts).reset_index(name="female_share")
max_female = female_proportion.sort_values("female_share", ascending=False).head(1)

print(max_female)
max_female_dict = {}
max_female_dict[max_female["decade"].iloc[0]] = max_female["category"].iloc[0]
max_female_dict

